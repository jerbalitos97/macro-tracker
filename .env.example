# ── Frontend (Vite) ─────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Without these, the app runs in local-only mode (no auth, no cloud sync).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── MCP server (Vercel function at /api/mcp) ───────────────────
# These run server-side only and must be set as Production env vars
# on Vercel (Settings → Environment Variables). Don't ship them in
# the client bundle.

# Same URL as VITE_SUPABASE_URL but without the VITE_ prefix.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Settings → API → service_role (secret). Bypasses RLS, so
# the MCP can read your data without a JWT. Never expose this client-side.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Random Bearer token shared between the MCP server and Claude.ai's
# custom connector. Generate with: openssl rand -hex 32
MCP_API_KEY=replace-with-a-long-random-string

# Your auth.users.id UUID — the MCP scopes every query to this user.
MCP_USER_ID=00000000-0000-0000-0000-000000000000
